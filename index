  recs.push({i:'🕳',t:`Install Recharge Pits — ${c.pitVol} m³ Total`,d:`Based on your ${ST.returnPeriod}-year design storm (${ST.designRainfall} mm/day) and a percolation rate of ${document.getElementById('inPerc').value} mm/hr, you need ${c.pitVol} m³ of recharge capacity distributed across low points in the catchment.`,p:'Critical',pc:'pri-c'});
  recs.push({i:'🏗',t:`${c.tankKL.toLocaleString()} KL Sealed Storage Tank`,d:`To cover your ${(ST.waterDemandLpd/1000).toFixed(1)} KL/day demand through the 45-day Mar–May dry window, a sealed sump or underground tank of ${c.tankKL.toLocaleString()} KL is required.`,p:'Critical',pc:'pri-c'});
  if(c.drainLen>20)recs.push({i:'🌿',t:`${c.drainLen}m French Drain / Bioswale`,d:`Design storm overflow must be channelled safely off-site. A ${c.drainLen}m French drain with bioswale edges adds ecological value as a pollinator corridor while protecting against flood risk.`,p:'High',pc:'pri-h'});
  if(c.surplus<0)recs.push({i:'⚠️',t:'Rainwater Alone Insufficient — Supplement Required',d:`Your annual harvest (${c.harvestKL.toLocaleString()} KL) covers ${c.selfSuff}% of annual demand (${c.annDemandKL.toLocaleString()} KL). Consider borewell recharge integration, greywater recycling, or demand-side reduction.`,p:'Medium',pc:'pri-m'});
  recs.push({i:'🦋',t:'Plant Native Species — Vetiver + Pongam Priority',d:`Vetiver (root depth 3–4m) and Pongam are highest priority for this bioregion. Both dramatically boost soil percolation rates and require minimal irrigation post-establishment.`,p:'Recommended',pc:'pri-r'});

  document.getElementById('rptRecs').innerHTML=recs.map(r=>
    `<div class="rec"><div class="rec-ico ${r.p==='Critical'?'a':'g'}">${r.i}</div>
     <div><div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.3rem;">
       <div class="rec-title">${r.t}</div><span class="pri ${r.pc}">${r.p}</span></div>
       <div class="rec-desc">${r.d}</div></div></div>`
  ).join('');

  // Specs table
  document.getElementById('specsTbody').innerHTML=[
    ['Total Project Site','— Input',`${ST.totalAreaSqm.toLocaleString()} m²`,`${(ST.totalAreaSqm/10000).toFixed(2)} Ha`],
    ['Active Catchment (A)','— Input',`${ST.activeAreaSqm.toLocaleString()} m²`,`${(ST.activeAreaSqm/10000).toFixed(2)} Ha`],
    ['Composite C','Σ(Cᵢ × %ᵢ) / 100',`C values: 0.90/0.35/0.15/0.05`,ST.compositeC.toFixed(2)],
    ['Design Rainfall',`Gumbel EVT · T=${ST.returnPeriod}yr`,`AMS mean + K_T × σ`,`${ST.designRainfall} mm/day`],
    ['Design Intensity','i = D_rain × Tc (0.42)',`${ST.designRainfall} × 0.42`,`${ST.designIntensity} mm/hr`],
    ['Peak Runoff (Q)','Q = C·i·A ÷ 360',`${ST.compositeC.toFixed(2)} × ${ST.designIntensity} × ${(ST.activeAreaSqm/10000).toFixed(2)}`,`${c.Q_m3s.toFixed(4)} m³/s`],
    ['Annual Harvest','V = A × R̄ × (1−C)',`${ST.activeAreaSqm.toLocaleString()} m² × ${Math.round(c.avgRain)} mm`,`${c.harvestKL.toLocaleString()} KL/yr`],
    ['Recharge Pit','V_pit = Q·t·1.3/1000',`${c.Q_lhr.toLocaleString()} L/hr · SF=1.3`,`${c.pitVol} m³`],
    ['Storage Tank','Demand × 45 days',`${(ST.waterDemandLpd/1000).toFixed(1)} KL/day × 45`,`${c.tankKL.toLocaleString()} KL`],
    ['French Drain','L = Q_ov / perc_rate',`${c.Q_lhr.toLocaleString()} L/hr overflow`,`${c.drainLen} m`],
  ].map(([p,f,inp,res])=>`<tr><td><strong>${p}</strong></td><td style="font-family:monospace;font-size:.8rem;">${f}</td><td style="color:var(--text3);">${inp}</td><td><strong style="color:var(--forest);">${res}</strong></td></tr>`).join('');

  // ILI Alignment
  const npc=+document.getElementById('sNative').value;
  const iliData=[
    {ico:'💧',t:'Water Ledger™',v:c.harvestKL.toLocaleString()+' KL',d:'Annual Harvest Potential recorded'},
    {ico:'🌿',t:'Carbon Ledger™',v:Math.round(npc*ST.activeAreaSqm/10000*2.5)+' tCO₂eq',d:'Estimated sequestration potential'},
    {ico:'🏆',t:'GDHI™ Score',v:c.score+' / 100',d:'Greenscape Designz Happiness Index'}
  ];
  document.getElementById('iliGrid').innerHTML=iliData.map(x=>
    `<div class="ili-card"><div style="font-size:1.6rem;margin-bottom:.5rem;">${x.ico}</div>
     <div style="font-weight:700;color:var(--forest);margin-bottom:.3rem;">${x.t}</div>
     <div class="ili-val">${x.v}</div>
     <div style="font-size:.8rem;color:var(--text3);margin-top:.4rem;line-height:1.4;">${x.d}</div></div>`
  ).join('');
}

// ============================================================
// LIVE DATA FETCH (Open-Meteo)
// ============================================================
async function fetchLive(){
  const lat=+document.getElementById('lat').value;
  const lon=+document.getElementById('lon').value;
  showLoad('Connecting to Open-Meteo Archive API…');
  try{
    const url=`https://archive-api.open-meteo.com/v1/archive?latitude=${lat}&longitude=${lon}&start_date=1999-01-01&end_date=2024-12-31&daily=precipitation_sum&elevation=NaN&timezone=auto`;
    updLoad('Downloading 25 years of daily rainfall data & elevation…');
    const res=await fetch(url);
    if(!res.ok)throw new Error('API fail');
    const json=await res.json();
    
    // Set Elevation
    if(json.elevation) {
      document.getElementById('elev').value = Math.round(json.elevation);
      document.getElementById('dElev').textContent = Math.round(json.elevation) + ' m';
    }

    const dates=json.daily.time, precip=json.daily.precipitation_sum;
    updLoad('Processing annual maximum series…');
    const byY={};
    dates.forEach((d,i)=>{
      const y=d.split('-')[0];
      if(!byY[y])byY[y]={year:+y,months:Array(12).fill(0),total:0,maxDay:0};
      const m=+d.split('-')[1]-1;
      const p=precip[i]||0;
      byY[y].months[m]+=p;byY[y].total+=p;
      if(p>byY[y].maxDay)byY[y].maxDay=p;
    });
    ST.annualData=Object.values(byY).filter(d=>d.year>=1999&&d.year<=2024).map(d=>({...d,total:Math.round(d.total),maxDay:Math.round(d.maxDay)}));
    computeAMS();
    
    ST.analysisRun=true;
    isSimulated=false;
    cTheme = C_LIVE; // Switch to vibrant brand colors
    
    const bdg='<span class="dot"></span>Live Open-Meteo · '+lat.toFixed(3)+'°N';
    document.getElementById('globalBadge').className='badge badge-live';document.getElementById('globalBadge').innerHTML=bdg;
    document.getElementById('t2Badge').className='badge badge-live';document.getElementById('t2Badge').innerHTML=bdg;
    hideLoad();toast('✅ Live data loaded — '+ST.annualData.length+' years & elevation gathered.');
    goTab(2);
  }catch(e){
    hideLoad();toast('⚠ Live fetch unavailable — falling back to sample data.');
    useSim();
  }
}

function useSim(){
  genSimData();
  ST.analysisRun=true;
  isSimulated=true;
  cTheme = C_SIM; // Switch to muted sim colors
  
  document.getElementById('globalBadge').className='badge badge-sim';document.getElementById('globalBadge').innerHTML='<span class="dot"></span>Sample / Simulated Data';
  toast('📊 Local sample data loaded.');
  goTab(2);
}

// ============================================================
// HELPERS
// ============================================================
function showLoad(m){document.getElementById('loading').classList.add('show');document.getElementById('lmsg').textContent=m;}
function hideLoad(){document.getElementById('loading').classList.remove('show');}
function updLoad(m){document.getElementById('lmsg').textContent=m;}
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3500);}
function tgl(id){document.getElementById(id).classList.toggle('open');}
