  const w=+document.getElementById('sWater').value;
  document.getElementById('pHard').textContent=h+'%';
  document.getElementById('pSoft').textContent=s+'%';
  document.getElementById('pNative').textContent=n+'%';
  document.getElementById('pWater').textContent=w+'%';
  
  const C=(h*0.90+s*0.35+n*0.15+w*0.05)/100;
  ST.compositeC=Math.round(C*100)/100;
  document.getElementById('cVal').textContent=ST.compositeC.toFixed(2);
  
  const r=C<0.25?'Excellent — very low runoff':C<0.45?'Moderate · Good balance':C<0.65?'High — increase native planting':'Very High — redesign surface mix';
  document.getElementById('cRating').innerHTML=r+'<br><span style="opacity:.7;font-size:.75rem;font-weight:normal;">Lower = better water retention</span>';
  if(document.getElementById('eC'))document.getElementById('eC').textContent=ST.compositeC.toFixed(2);
}

function cvtArea(){
  const act = +document.getElementById('siteArea').value;
  const tot = +document.getElementById('totalArea').value;
  const u = document.getElementById('areaUnit').value;
  
  // Set UI label for total unit
  document.getElementById('uT').textContent = u==='sqm'?'m²':u==='acres'?'Ac':'Ha';
  
  let actSqm=u==='sqm'?act:u==='acres'?act*4046.86:act*10000;
  let totSqm=u==='sqm'?tot:u==='acres'?tot*4046.86:tot*10000;
  
  // Prevent active area from exceeding total
  if(actSqm > totSqm) { actSqm = totSqm; document.getElementById('siteArea').value = tot; }
  
  ST.activeAreaSqm = actSqm;
  ST.totalAreaSqm = totSqm;
  
  document.getElementById('areaConvHint').textContent=`Catchment: ≈ ${(actSqm/4046.86).toFixed(2)} Acres · ${(actSqm/10000).toFixed(2)} Hectares`;
  
  // Update Visual Bar
  let pct = totSqm > 0 ? Math.round((actSqm / totSqm) * 100) : 0;
  document.getElementById('vizPct').textContent = pct + '%';
  document.getElementById('vizFill').style.width = pct + '%';
  
  if(document.getElementById('eA'))document.getElementById('eA').textContent=(actSqm/10000).toFixed(2);
}

