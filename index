// ============================================================
// DATA GENERATION / HANDLING
// ============================================================
function genSimData(){
  ST.annualData=[];
  // Add a distinct offset so simulated data looks noticeably different from live BLR data
  const simOffset = 0.65; 
  const seeds=[1.0,0.82,1.12,0.67,1.05,0.78,1.28,0.91,1.03,0.88,1.15,0.72,1.09,0.84,1.22,0.76,0.99,1.18,0.83,1.07,0.71,1.25,0.94,1.01,0.87];
  for(let y=0;y<25;y++){
    const ym=seeds[y]*(0.92+Math.random()*0.16) * simOffset;
    const months=BASE_MONTHLY.map(m=>Math.max(0,m*ym*(0.78+Math.random()*0.44)));
    const total=Math.round(months.reduce((a,b)=>a+b,0));
    const maxDay=Math.round(months[8]*0.38+Math.random()*months[8]*0.22);
    ST.annualData.push({year:YEARS25[y],months,total,maxDay});
  }
  computeAMS();
}

function computeAMS(){
  const a=ST.annualData.map(d=>({year:d.year,maxDay:d.maxDay})).sort((a,b)=>b.maxDay-a.maxDay);
  const N=a.length;
  ST.ams=a.map((d,i)=>({...d,rank:i+1,returnPeriod:((N+1)/(i+1)).toFixed(1)}));
}

function computeStorm(T){
  const vals=ST.ams.map(d=>d.maxDay);
  const mean=vals.reduce((a,b)=>a+b,0)/vals.length;
  const sd=Math.sqrt(vals.reduce((a,b)=>a+Math.pow(b-mean,2),0)/vals.length);
  const y_T=-Math.log(-Math.log(1-1/T));
  const K_T=(y_T-0.5362)/1.0915;
  const dr=Math.max(30,Math.round(mean+K_T*sd));
  return {designRainfall:dr, designIntensity:Math.max(12,Math.round(dr*0.42))};
}

