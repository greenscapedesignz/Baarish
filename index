<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RainSite Intelligence™ | GDHI Framework</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
:root{
  --bg:#f4f7f6; --surface:#ffffff; --surface2:#ebf0ee; --border:#cbd6d1;
  --forest:#14452f; --forest2:#1f5e42; --forest3:#2d7a58; --forest-light:#e2ede8;
  --water:#0f5282; --water2:#166a9e; --water-light:#dbeafe;
  --amber:#b5620a; --amber2:#d97730; --amber-light:#fef3c7;
  --red:#b91c1c; --green:#15803d;
  --text:#1a2420; --text2:#3d5248; --text3:#738c80; --text4:#a3b8ad;
  --shadow:0 2px 14px rgba(20,69,47,.08); --shadow-lg:0 8px 36px rgba(20,69,47,.12);
  --radius:8px; --radius-sm:5px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:"Helvetica Neue", Helvetica, Arial, sans-serif;background:var(--bg);color:var(--text);min-height:100vh; line-height: 1.5;}

/* HEADER */
.hdr{background:linear-gradient(135deg,var(--forest) 0%,#0a2e1d 100%);color:#fff;padding:1rem 1.75rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;box-shadow:0 3px 20px rgba(0,0,0,.15);}
.hdr-brand{display:flex;align-items:center;gap:.85rem;}
.hdr-icon{width:42px;height:42px;background:rgba(255,255,255,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;}
.hdr h1{font-size:1.3rem;font-weight:700;letter-spacing:-.02em;}
.hdr p{font-size:.75rem;opacity:.8;margin-top:.1rem;}
.hdr-right{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;}

/* STEP NAV */
.snav{background:#fff;border-bottom:1px solid var(--border);padding:0 1.5rem;display:flex;overflow-x:auto;gap:0;}
.snav-btn{padding:.85rem 1.25rem;border:none;background:none;cursor:pointer;font-family:inherit;font-size:.85rem;font-weight:500;color:var(--text3);border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;display:flex;align-items:center;gap:.5rem;}
.snav-btn:hover{color:var(--forest);}
.snav-btn.active{color:var(--forest);border-bottom-color:var(--forest);font-weight:700;}
.snav-btn.done{color:var(--forest2);}
.snum{width:22px;height:22px;border-radius:50%;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;transition:all .2s;}
.snav-btn.active .snum{background:var(--forest);color:#fff;}
.snav-btn.done .snum{background:var(--green);color:#fff;}

/* MAIN */
.main{max-width:1380px;margin:0 auto;padding:1.75rem;}
.panel{display:none;} .panel.active{display:block;}

/* CARDS */
.card{background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;box-shadow:var(--shadow);}
.card-title{font-size:1.1rem;font-weight:700;color:var(--forest);margin-bottom:.3rem;letter-spacing:-.01em;}
.card-sub{font-size:.8rem;color:var(--text3);margin-bottom:1.2rem;line-height:1.4;}

/* GRIDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;}
@media(max-width:1100px){.g4{grid-template-columns:1fr 1fr;}.g3{grid-template-columns:1fr 1fr;}}
@media(max-width:700px){.g2,.g3,.g4{grid-template-columns:1fr;}.main{padding:1rem;}}

/* METRIC CARDS */
.metric{background:#fff;border:1px solid var(--border);border-radius:var(--radius);padding:1.2rem;position:relative;overflow:hidden;}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;}
.metric.green::before{background:var(--forest);}
.metric.blue::before{background:var(--water);}
.metric.amber::before{background:var(--amber);}
.metric.red::before{background:var(--red);}
.metric-lbl{font-size:.7rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);font-weight:700;margin-bottom:.3rem;}
.metric-val{font-size:1.8rem;font-weight:700;color:var(--text);line-height:1;letter-spacing:-.02em;}
.metric-val .u{font-size:.85rem;font-weight:500;color:var(--text3);margin-left:.15rem;}
.metric-sub{font-size:.75rem;color:var(--text3);margin-top:.4rem;}
.metric-ico{font-size:1.2rem;margin-bottom:.4rem;}

/* FORM */
.fg{margin-bottom:1.2rem;}
.flbl{display:block;font-size:.85rem;font-weight:600;color:var(--text2);margin-bottom:.4rem;}
.fhint{font-size:.75rem;color:var(--text3);margin-top:.3rem;}
.finput,.fsel{width:100%;padding:.6rem .85rem;border:1px solid var(--border);border-radius:var(--radius-sm);font-family:inherit;font-size:.9rem;color:var(--text);background:#fff;outline:none;transition:border-color .2s;}
.finput:focus,.fsel:focus{border-color:var(--forest);box-shadow:0 0 0 3px rgba(20,69,47,.1);}
.igrp{display:flex;gap:.5rem;}
.igrp .finput{flex:1;}
.ubadge{padding:.6rem .85rem;background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);font-size:.8rem;font-weight:600;color:var(--text2);white-space:nowrap;}

/* RANGE */
.rng-row{display:flex;align-items:center;gap:1rem;}
.rng{flex:1;-webkit-appearance:none;height:6px;background:var(--surface2);border:1px solid var(--border);border-radius:3px;outline:none;}
.rng::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:var(--forest);border-radius:50%;cursor:pointer;transition:transform .15s;}
.rng::-webkit-slider-thumb:hover{transform:scale(1.15);}
.rng-val{min-width:45px;text-align:right;font-size:.85rem;font-weight:700;color:var(--forest);}

/* BUTTONS */
.btn{padding:.65rem 1.25rem;border-radius:var(--radius-sm);border:none;cursor:pointer;font-family:inherit;font-size:.85rem;font-weight:700;transition:all .2s;display:inline-flex;align-items:center;justify-content:center;gap:.5rem;}
.btn-primary{background:var(--forest);color:#fff;}
.btn-primary:hover{background:var(--forest2);transform:translateY(-1px);box-shadow:var(--shadow);}
.btn-sec{background:var(--surface2);color:var(--forest);border:1px solid var(--border);}
.btn-sec:hover{background:var(--border);}
.btn-blue{background:var(--water);color:#fff;}
.btn-blue:hover{background:var(--water2);}

/* BADGE */
.badge{display:inline-flex;align-items:center;gap:.3rem;padding:.25rem .75rem;border-radius:20px;font-size:.75rem;font-weight:700;letter-spacing:.02em;}
.badge .dot{width:8px;height:8px;border-radius:50%;background:currentColor;}
.badge-sim{background:#fef3c7;color:#92400e; border:1px solid #fde68a;}
.badge-live{background:#dcfce7;color:#14532d; border:1px solid #bbf7d0;}

/* TABLE */
.dtbl{width:100%;border-collapse:collapse;font-size:.85rem;}
.dtbl th{text-align:left;padding:.6rem .8rem;background:var(--surface2);color:var(--forest);font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid var(--border);}
.dtbl td{padding:.6rem .8rem;border-bottom:1px solid var(--border);color:var(--text2);}
.dtbl tr:hover td{background:var(--surface2);}

/* RWH REC CARDS */
.rec{display:flex;gap:1rem;padding:1.2rem;background:#fff;border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:1rem;}
.rec-ico{width:46px;height:46px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.rec-ico.g{background:#dcfce7;} .rec-ico.b{background:#dbeafe;} .rec-ico.a{background:#fef3c7;}
.rec-title{font-weight:700;font-size:.95rem;color:var(--text);margin-bottom:.2rem;}
.rec-desc{font-size:.82rem;color:var(--text2);line-height:1.5;}
.rec-spec{margin-top:.5rem;padding:.4rem .7rem;background:var(--surface2);border-radius:5px;font-size:.8rem;color:var(--forest);font-weight:600;}

/* RETURN PERIOD SELECTOR */
.rp-wrap{display:flex;gap:.5rem;flex-wrap:wrap;}
.rp-btn{padding:.4rem .9rem;border:1px solid var(--border);border-radius:20px;background:#fff;cursor:pointer;font-size:.85rem;font-weight:600;color:var(--text2);transition:all .2s;font-family:inherit;}
.rp-btn:hover{border-color:var(--forest);}
.rp-btn.active{background:var(--forest);border-color:var(--forest);color:#fff;}

/* COORD BOX */
.coord-box{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:.8rem 1rem;display:flex;align-items:center;gap:1.2rem;font-size:.85rem;}
.coord-kv{display:flex;flex-direction:column;gap:.1rem;}
.ck{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--text3);font-weight:700;}
.cv{font-weight:700;color:var(--text);font-size:1rem;}
.div-v{width:1px;height:32px;background:var(--border);}

/* C-FACTOR BAR */
.c-bar{background:var(--forest);color:#fff;border-radius:8px;padding:1rem 1.2rem;display:flex;justify-content:space-between;align-items:center;}
.c-val{font-size:1.7rem;font-weight:700;letter-spacing:-.02em;}

/* VISUAL BAR (CATCHMENT VS SITE) */
.area-viz-wrap {width: 100%; background: var(--surface2); border-radius: 6px; height: 16px; overflow: hidden; position: relative; border: 1px solid var(--border); margin-top: .5rem;}
.area-viz-fill {height: 100%; background: var(--water); transition: width 0.3s ease;}

/* CHART CONTAINER */
.ch-wrap{position:relative;height:240px;}
.ch-sm{height:180px;}

/* PROJECTION ROW */
.proj-row{display:grid;grid-template-columns:90px 1fr 1fr 1fr;gap:.5rem;padding:.6rem 0;border-bottom:1px solid var(--border);align-items:center;font-size:.85rem;}
.proj-row.hdr{font-weight:700;color:var(--text3);font-size:.75rem;text-transform:uppercase;letter-spacing:.05em;}
.vg{color:var(--green);font-weight:700;} .vw{color:#d97706;font-weight:700;} .vb{color:var(--red);font-weight:700;}

/* FORMULA BOX */
.fml{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:.8rem 1rem;font-family:monospace;font-size:.85rem;color:var(--forest);margin-top:.8rem;line-height:1.6;}

/* REPORT HEADER */
.rpt-hdr{background:linear-gradient(135deg,var(--forest) 0%,#0a2e1d 100%);color:#fff;border-radius:var(--radius);padding:1.75rem;margin-bottom:1.5rem;}
.rpt-title{font-size:1.8rem;font-weight:700;margin-bottom:.3rem;letter-spacing:-.02em;}
.rpt-sub{font-size:.85rem;opacity:.8;}

/* SECTION HEADER */
.sec-hdr{margin-bottom:1.5rem;}
.sec-title{font-size:1.5rem;font-weight:700;color:var(--forest);letter-spacing:-.02em;}
.sec-desc{font-size:.9rem;color:var(--text2);margin-top:.3rem;}

/* LOADING OVERLAY */
.loading{display:none;position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:999;align-items:center;justify-content:center;flex-direction:column;gap:1rem;color:#fff;}
.loading.show{display:flex;}
.spin{width:42px;height:42px;border:4px solid rgba(255,255,255,.25);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* TOAST */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--forest);color:#fff;padding:.8rem 1.2rem;border-radius:8px;font-size:.85rem;font-weight:600;box-shadow:var(--shadow-lg);z-index:500;transform:translateY(80px);opacity:0;transition:all .3s;}
.toast.show{transform:translateY(0);opacity:1;}

/* SPECIES GRID */
.spc-card{padding:.8rem;background:var(--surface2);border-radius:8px;font-size:.8rem;}
.spc-name{font-weight:700;color:var(--text);}
.spc-sci{font-style:italic;color:var(--text3);font-size:.75rem;}
.spc-role{color:var(--forest);font-size:.75rem;font-weight:700;margin:.2rem 0;}
.spc-ben{color:var(--text2);font-size:.75rem;}

/* ILI CARD */
.ili-card{padding:1.2rem;background:var(--surface2);border-radius:var(--radius-sm);text-align:center;}
.ili-val{font-size:1.5rem;font-weight:700;color:var(--text);letter-spacing:-.02em;}

</style>
</head>
<body>

<div class="loading" id="loading">
  <div class="spin"></div>
  <div style="font-size:1rem; font-weight: 700;">Fetching live climate & topographical data…</div>
  <div style="font-size:.85rem;opacity:.8;" id="lmsg">Connecting to Open-Meteo…</div>
</div>
<div class="toast" id="toast"></div>

<header class="hdr">
  <div class="hdr-brand">
    <div class="hdr-icon">🌿</div>
    <div>
      <h1>RainSite Intelligence™</h1>
      <p>Integrated Landscape Intelligence · GDHI Framework</p>
    </div>
  </div>
  <div class="hdr-right">
    <span class="badge badge-sim" id="globalBadge"><span class="dot"></span>Simulated Data</span>
    <button class="btn btn-sec" style="font-size:.8rem; padding: .4rem .8rem; background: rgba(255,255,255,0.1); color: white; border-color: rgba(255,255,255,0.2);" onclick="window.print()">⬇ Export Report</button>
  </div>
</header>

<nav class="snav">
  <button class="snav-btn active" id="sb1" onclick="goTab(1)"><span class="snum">1</span>Site Setup</button>
  <button class="snav-btn" id="sb2" onclick="goTab(2)"><span class="snum">2</span>Rainfall Intelligence</button>
  <button class="snav-btn" id="sb3" onclick="goTab(3)"><span class="snum">3</span>Engineering Analysis</button>
  <button class="snav-btn" id="sb4" onclick="goTab(4)"><span class="snum">4</span>Strategic Report</button>
</nav>

<main class="main">

<div class="panel active" id="tab1">
  <div class="sec-hdr">
    <div class="sec-title">🗺 Configure Your Site</div>
    <div class="sec-desc">Enter your coordinates and site parameters. The system pulls 25 years of climate, soil &amp; ecological intelligence for your exact location.</div>
  </div>

  <div class="g2">
    <div style="display:flex;flex-direction:column;gap:1.5rem;">

      <div class="card">
        <div class="card-title">📍 Location & Topography</div>
        <div class="card-sub">Enter GPS coordinates or fetch live elevation data</div>
        <div class="fg">
          <label class="flbl">Project / Site Name</label>
          <input class="finput" id="siteName" value="Sample Site — Bengaluru" placeholder="e.g. Hasiru Harmony Phase 1">
        </div>
        <div class="g3" style="gap:.8rem;">
          <div class="fg">
            <label class="flbl">Latitude</label>
            <input type="number" class="finput" id="lat" value="12.9716" step=".0001">
          </div>
          <div class="fg">
            <label class="flbl">Longitude</label>
            <input type="number" class="finput" id="lon" value="77.5946" step=".0001">
          </div>
          <div class="fg">
            <label class="flbl">Elevation (m)</label>
            <input type="number" class="finput" id="elev" value="920" step="1">
          </div>
        </div>
        
        <div class="coord-box" id="coordBox">
          <span style="font-size:1.3rem;">📌</span>
          <div class="coord-kv"><span class="ck">Latitude</span><span class="cv" id="dLat">12.9716°N</span></div>
          <div class="div-v"></div>
          <div class="coord-kv"><span class="ck">Longitude</span><span class="cv" id="dLon">77.5946°E</span></div>
          <div class="div-v"></div>
          <div class="coord-kv"><span class="ck">Elevation</span><span class="cv" id="dElev">920 m</span></div>
        </div>
        <div style="display:flex;gap:.8rem;margin-top:1.2rem;">
          <button class="btn btn-blue" onclick="fetchLive()" style="flex:1;">🌐 Fetch Live Coordinates Data</button>
          <button class="btn btn-sec" onclick="useSim()" style="flex:1;">📊 Use Sample Data</button>
        </div>
      </div>

      <div class="card">
        <div class="card-title">📐 Project Size & Catchment</div>
        <div class="card-sub">Define the total project size vs. the specific area actively harvested</div>
        
        <div class="fg">
          <label class="flbl">Project Typology</label>
          <select class="fsel" id="projType" onchange="applyDefaults()">
            <option value="villa">Residential — Villa / Independent House</option>
            <option value="campus" selected>Residential — Campus / Layout (1–10 acres)</option>
            <option value="institutional">Institutional — School / Hospital / Campus</option>
            <option value="resort">Resort / Hospitality</option>
            <option value="public">Public Infrastructure / Park</option>
            <option value="industrial">Industrial / Commercial</option>
          </select>
        </div>

        <div class="g2" style="gap:1rem;">
          <div class="fg">
            <label class="flbl">Total Project Size</label>
            <div class="igrp">
              <input type="number" class="finput" id="totalArea" value="12000" oninput="cvtArea()">
              <span class="ubadge" id="uT">m²</span>
            </div>
          </div>
          <div class="fg">
            <label class="flbl">Active Catchment Area</label>
            <div class="igrp">
              <input type="number" class="finput" id="siteArea" value="10000" oninput="cvtArea()">
              <select class="fsel" id="areaUnit" style="width:70px; padding: .6rem .4rem;" onchange="cvtArea()">
                <option value="sqm">m²</option>
                <option value="acres">Ac</option>
                <option value="hectares">Ha</option>
              </select>
            </div>
          </div>
        </div>
        
        <div class="fhint" style="margin-top:0;" id="areaConvHint">Catchment: ≈ 2.47 Acres · 1.00 Hectare</div>
        
        <div style="margin-top: 1rem;">
          <div style="display:flex; justify-content:space-between; font-size:.75rem; font-weight:700; color:var(--text3);">
            <span>Catchment Utilization</span>
            <span id="vizPct">83%</span>
          </div>
          <div class="area-viz-wrap">
            <div class="area-viz-fill" id="vizFill" style="width: 83%;"></div>
          </div>
        </div>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:1.5rem;">

      <div class="card">
        <div class="card-title">🏗 Land Use Breakdown (Catchment)</div>
        <div class="card-sub">Adjust surface composition. Affects runoff coefficient (C) and harvest potential.</div>

        <div class="fg">
          <label class="flbl">🏛 Built / Hard Surface <small style="opacity:.6; font-weight:normal;">(C=0.90)</small> <span class="rng-val" id="pHard" style="float:right;">30%</span></label>
          <div class="rng-row"><input type="range" class="rng" id="sHard" min="0" max="100" value="30" oninput="calcC()"></div>
        </div>
        <div class="fg">
          <label class="flbl">🌱 Lawn / Soft Landscape <small style="opacity:.6; font-weight:normal;">(C=0.35)</small> <span class="rng-val" id="pSoft" style="float:right;">40%</span></label>
          <div class="rng-row"><input type="range" class="rng" id="sSoft" min="0" max="100" value="40" oninput="calcC()"></div>
        </div>
        <div class="fg">
          <label class="flbl">🌳 Native / Deep-Root Planting <small style="opacity:.6; font-weight:normal;">(C=0.15)</small> <span class="rng-val" id="pNative" style="float:right;">20%</span></label>
          <div class="rng-row"><input type="range" class="rng" id="sNative" min="0" max="100" value="20" oninput="calcC()"></div>
        </div>
        <div class="fg">
          <label class="flbl">💧 Water / Open Soil <small style="opacity:.6; font-weight:normal;">(C=0.05)</small> <span class="rng-val" id="pWater" style="float:right;">10%</span></label>
          <div class="rng-row"><input type="range" class="rng" id="sWater" min="0" max="100" value="10" oninput="calcC()"></div>
        </div>

        <div class="c-bar" style="margin-top: 1.5rem;">
          <div>
            <div style="font-size:.75rem;opacity:.8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:.2rem;">Composite Runoff Coeff. (C)</div>
            <div class="c-val" id="cVal">0.43</div>
          </div>
          <div style="text-align:right;font-size:.85rem;opacity:.9; font-weight: 600;" id="cRating">Moderate · Good balance<br><span style="opacity:.7;font-size:.75rem; font-weight:normal;">Lower = more infiltration</span></div>
        </div>
      </div>

      <div class="card">
        <div class="card-title">🪨 Soil Profile &amp; Demand</div>
        <div class="card-sub">Select a preset to load typical soil data, or manually manage specific values.</div>
        
        <div class="fg">
          <label class="flbl">Soil Preset Loader</label>
          <select class="fsel" id="soilType" onchange="updateSoil()">
            <option value="red_laterite" selected>Red Laterite (Bengaluru Plateau)</option>
            <option value="black_cotton">Black Cotton Soil (North Karnataka)</option>
            <option value="alluvial">Alluvial (River Plains)</option>
            <option value="sandy_loam">Sandy Loam</option>
            <option value="clay">Heavy Clay</option>
            <option value="rocky">Rocky / Shallow Soil</option>
          </select>
        </div>
        
        <div class="g2" style="gap:1rem; padding: 1rem; background: var(--surface2); border-radius: var(--radius-sm); border: 1px solid var(--border); margin-bottom: 1.2rem;">
          <div>
            <label class="flbl" style="font-size:.8rem;">Percolation Rate (mm/hr)</label>
            <input type="number" class="finput" id="inPerc" value="18" step="1" style="padding:.4rem .6rem;">
          </div>
          <div>
            <label class="flbl" style="font-size:.8rem;">Field Capacity (%)</label>
            <input type="number" class="finput" id="inFC" value="35" step="1" style="padding:.4rem .6rem;">
          </div>
        </div>

        <div class="fg" style="margin-bottom:0;">
          <label class="flbl">Estimated Daily Water Demand</label>
          <div class="igrp">
            <input type="number" class="finput" id="demand" value="50000">
            <span class="ubadge">Liters / day</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div style="display:flex;justify-content:flex-end;margin-top:1.5rem;">
    <button class="btn btn-primary" onclick="runAnalysis()" style="font-size: 1rem; padding: .8rem 1.5rem;">Generate GDHI Intelligence →</button>
  </div>
</div>


<div class="panel" id="tab2">
