// ============================================================
// ENGINEERING CALCULATIONS
// ============================================================
function doEngCalc(){
  const C=ST.compositeC;
  const i=ST.designIntensity;
  const A=ST.activeAreaSqm/10000; // ha, uses active catchment
  
  const percRate = +document.getElementById('inPerc').value || 18;
  const ann=ST.annualData.map(d=>d.total);
  const avgRain=ann.reduce((a,b)=>a+b,0)/ann.length;

  // Rational method
  const Q_m3s=(C*i*A)/360;
  const Q_lhr=Math.round(C*i*ST.activeAreaSqm);

  // Annual harvest
  const harvestKL=Math.round(avgRain*ST.activeAreaSqm*(1-C)/1000);

  // Pit: absorb 1-hr peak inflow minus percolation capacity, 30% safety factor
  const stormInflow=i*ST.activeAreaSqm; // L/hr
  const pitVol=Math.max(5,Math.round(stormInflow*C/1000*1.3));

  // Tank: 45-day dry season buffer
  const tankKL=Math.round(ST.waterDemandLpd*45/1000);

  // French drain length
  const drainLen=Math.max(10,Math.round((Q_lhr*0.25)/(percRate*500)*1000));

  // Balance
  const annDemandKL=Math.round(ST.waterDemandLpd*365/1000);
  const selfSuff=Math.min(100,Math.round(harvestKL/annDemandKL*100));
  const surplus=harvestKL-annDemandKL;
  const score=Math.min(100,Math.round(50+(1-C)*30+(+document.getElementById('sNative').value/100)*20));

  ST.calc={Q_m3s,Q_lhr,harvestKL,pitVol,tankKL,drainLen,annDemandKL,selfSuff,surplus,avgRain,score};

  // Update tab3 metrics
  document.getElementById('eQ').innerHTML=Q_lhr.toLocaleString()+'<span class="u">L/hr</span>';
  document.getElementById('eHarv').innerHTML=harvestKL.toLocaleString()+'<span class="u">KL/yr</span>';
  document.getElementById('ePit').innerHTML=pitVol+'<span class="u">m³</span>';
  document.getElementById('eSelf').innerHTML=selfSuff+'<span class="u">%</span>';

  document.getElementById('eC').textContent=C.toFixed(2);
  document.getElementById('eI').textContent=i;
  document.getElementById('eA').textContent=A.toFixed(2);
  document.getElementById('qDisp').innerHTML=Q_m3s.toFixed(4)+' <small style="font-size:.85rem; font-weight:normal;">m³/s</small>';
  document.getElementById('qCtx').innerHTML=(Q_m3s<0.01?'Low Volume · Standard drains adequate':Q_m3s<0.05?'Moderate · French drain recommended':'High Volume · Bioswale + robust drains essential');
  document.getElementById('qPlain').textContent=Q_lhr.toLocaleString()+' litres';

  const sKey = document.getElementById('soilType').value;
  document.getElementById('pitSpec').textContent=`${pitVol} m³ total · ${Math.ceil(pitVol/5)} pits of ~5 m³ · Depth 2.5–3 m · ${SOILS[sKey].n} base`;
  document.getElementById('tankSpec').textContent=`${tankKL.toLocaleString()} KL · 45-day dry buffer · Demand: ${(ST.waterDemandLpd/1000).toFixed(1)} KL/day`;
  document.getElementById('drainSpec').textContent=`${drainLen} m French drain · 300mm perforated pipe · Gravel surround`;

  // Balance chart
  const mHarv=BASE_MONTHLY.map(m=>Math.round(m*ST.activeAreaSqm*(1-C)/1000));
  const mDem=Array(12).fill(Math.round(ST.waterDemandLpd*30.5/1000));
  dch('balance');
  CHS['balance']=new Chart(document.getElementById('chBalance'),{
    type:'bar',
    data:{labels:MONTHS,datasets:[
      {label:'Harvest (KL)',data:mHarv,backgroundColor:cTheme.bg_harv,borderRadius:4},
      {label:'Demand (KL)',data:mDem,backgroundColor:'rgba(185,28,28,.6)',borderRadius:4}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:12}}},scales:{y:{grid:{color:'#ebf0ee'}},x:{grid:{display:false}}}}
  });

  document.getElementById('aSupply').textContent=harvestKL.toLocaleString()+' KL';
  document.getElementById('aDemand').textContent=annDemandKL.toLocaleString()+' KL';
  const balEl=document.getElementById('aBalance');
  balEl.textContent=(surplus>=0?'+':'')+surplus.toLocaleString()+' KL';
  balEl.style.color=surplus>=0?'var(--green)':'var(--red)';

  // Projections
  [[0,'p0r','p0h',null],[5,'p5r','p5h','p5x'],[10,'p10r','p10h','p10x'],[25,'p25r','p25h','p25x']].forEach(([yr,rId,hId,rxId])=>{
    const f=1+(yr/10)*0.07;
    document.getElementById(rId).textContent=Math.round(avgRain*f)+' mm';
    document.getElementById(hId).textContent=Math.round(harvestKL*f).toLocaleString()+' KL';
    if(rxId){
      const risk=yr<=5?'<span class="vg">✓ Low</span>':yr<=10?'<span class="vw">⚠ Moderate</span>':'<span class="vb">⚡ High</span>';
      document.getElementById(rxId).innerHTML=risk;
    }
  });

  const pYrs=[0,5,10,15,20,25];
  dch('proj');
  CHS['proj']=new Chart(document.getElementById('chProj'),{
    type:'line',
    data:{labels:pYrs.map(y=>y===0?'Now':'+'+y+'yr'),datasets:[
      {label:'Rainfall (mm)',data:pYrs.map(y=>Math.round(avgRain*(1+(y/10)*0.07))),borderColor:cTheme.rain,fill:false,tension:.4,pointRadius:3},
      {label:'Harvest (KL)',data:pYrs.map(y=>Math.round(harvestKL*(1+(y/10)*0.07))),borderColor:cTheme.harvest,fill:false,tension:.4,pointRadius:3,borderDash:[4,2]}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:10}}},scales:{y:{grid:{color:'#ebf0ee'}},x:{grid:{display:false}}}}
  });

  // Irrigation chart
  const effRain=BASE_MONTHLY.map(m=>Math.round(m*0.7));
  const irrStd=ET_MONTHLY.map((e,idx)=>Math.max(0,e-effRain[idx]));
  const npc=+document.getElementById('sNative').value;
  const irrNat=irrStd.map(v=>Math.round(v*(1-npc/100*0.75)));
  dch('irrig');
  CHS['irrig']=new Chart(document.getElementById('chIrrig'),{
    type:'bar',
    data:{labels:MONTHS,datasets:[
      {label:'Standard Turf (mm)',data:irrStd,backgroundColor:'rgba(220,38,38,.4)',borderRadius:3},
      {label:'Native Planting (mm)',data:irrNat,backgroundColor:cTheme.bg_rain,borderRadius:3}
    ]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{font:{size:11},boxWidth:10}}},scales:{y:{grid:{color:'#ebf0ee'}},x:{grid:{display:false}}}}
  });
  document.getElementById('nativePctLbl').textContent=npc+'%';
  const irSav=Math.min(75,20+npc*1.5);
  document.getElementById('irrigSav').textContent='~'+(irSav-4).toFixed(0)+'–'+irSav.toFixed(0)+'%';

  // Species grid
  document.getElementById('speciesGrid').innerHTML=SPECIES.map(s=>
    `<div class="spc-card"><div style="font-size:1.2rem;margin-bottom:.3rem;">${s.i}</div><div class="spc-name">${s.n}</div><div class="spc-sci">${s.s}</div><div class="spc-role">${s.r}</div><div class="spc-ben">${s.b}</div></div>`
  ).join('');
}

